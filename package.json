{
  "name": "explocode",
  "version": "1.0.0",
  "private": true,
  "description": "Experiment and learning code collection",
  "workspaces": [
    "koa-demo"
  ],
  "scripts": {
    "koa": "node koa-demo/app.js",
    "cd": "node scripts/git-commit-date.mjs",
    "fastapi:install": "fastapi-demo/.venv/bin/pip install -r fastapi-demo/services/user-service/requirements.txt && fastapi-demo/.venv/bin/pip install -r fastapi-demo/services/order-service/requirements.txt && fastapi-demo/.venv/bin/pip install -r fastapi-demo/services/a/requirements.txt",
    "fastapi:a": "fastapi-demo/.venv/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 8003 --app-dir fastapi-demo/services/a",
    "fastapi:user": "fastapi-demo/.venv/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 8001 --app-dir fastapi-demo/services/user-service",
    "fastapi:order": "USER_SERVICE_URL=http://127.0.0.1:8001 fastapi-demo/.venv/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 8002 --app-dir fastapi-demo/services/order-service",
    "fastapi:up": "docker compose --project-directory fastapi-demo -f fastapi-demo/docker-compose.yml up --build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
